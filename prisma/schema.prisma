// 99 Technologies ERP - Full Schema
// Covers: Auth, Employee Lifecycle, Asset Management, Expenses, Finance/Payroll, Notifications, Audit

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// ENUMS
// ========================

enum UserRole {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
  ACCOUNTANT
}

enum EmploymentStatus {
  PERMANENT
  PROBATION
  CONSULTANT
}

enum EmployeeLifecycleStage {
  OFFER_SENT
  ONBOARDING
  PROVISIONING
  ACTIVE
  EXIT_INITIATED
  EXITED
}

enum AssetType {
  HARDWARE
  SOFTWARE
}

enum AssetCondition {
  NEW
  WORKING
  DAMAGED
  IN_REPAIR
  LOST
  RETIRED
}

enum ExpenseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum PayrollStatus {
  DRAFT
  FINALIZED
  PAID
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum NotificationType {
  ASSET_ASSIGNED
  ASSET_RETURNED
  ASSET_RETIRED
  EXPENSE_SUBMITTED
  EXPENSE_APPROVED
  EXPENSE_REJECTED
  EXPENSE_REVISION
  PAYROLL_FINALIZED
  PAYROLL_PAID
  EMPLOYEE_ONBOARDED
  EMPLOYEE_EXIT
  SYSTEM_ALERT
  GENERAL
}

enum OrgRelationshipType {
  SOLID
  DOTTED
}

enum JobTier {
  EXECUTIVE
  DIRECTOR
  MANAGER
  LEAD
  IC
}

// ========================
// USER & AUTH
// ========================

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(EMPLOYEE)
  employeeId   Int?      @unique
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  // Password reset: random hex stored here while a request is open.
  // Cleared as soon as the new password is set (single-use). Indexed
  // because lookups happen by token, not by user id.
  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee              Employee?         @relation(fields: [employeeId], references: [id])
  sessions              Session[]
  notifications         Notification[]
  expenseApprovals      ExpenseApproval[]
  auditLogs             AuditLog[]        @relation("AuditUser")
  orgAssignmentsCreated OrgAssignment[]   @relation("AssignmentCreatedBy")
  reviewedAccessRequests DigitalAccessRequest[]
  ledgerEntries         LedgerEntry[]
  bills                 Bill[]
  cheques               Cheque[]
  opexEntries           OpexEntry[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("sessions")
}

// ========================
// ORGANIZATION STRUCTURE
// ========================

model Company {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  country   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets                Asset[]
  assetsFrom            AssetTransfer[]        @relation("FromCompany")
  assetsTo              AssetTransfer[]        @relation("ToCompany")
  employees             Employee[]
  expenses              Expense[]
  payrollRuns           PayrollRun[]
  billingSplits         BillingSplit[]
  employeeCompanies     EmployeeCompany[]
  onboardingSubmissions OnboardingSubmission[]
  ledgerEntries         LedgerEntry[]
  bills                 Bill[]
  cheques               Cheque[]
  opexEntries           OpexEntry[]

  @@map("companies")
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String   @unique @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees             Employee[]
  expenses              Expense[]
  expenseCategories     ExpenseCategory[]
  onboardingSubmissions OnboardingSubmission[]

  @@map("departments")
}

model Location {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  address   String?
  country   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets    Asset[]
  employees Employee[]

  @@map("locations")
}

// ========================
// EMPLOYEE LIFECYCLE
// ========================

model Employee {
  id                       Int       @id @default(autoincrement())
  empCode                  String    @unique
  firstName                String
  lastName                 String
  fatherName               String?
  email                    String?
  // Organization / work email (e.g. @99technologies.com). Used for SSO
  // matching so personal `email` can stay as personal contact.
  workEmail                String?   @unique
  phone                    String?
  cnic                     String?
  dateOfBirth              DateTime?
  gender                   String?
  address                  String?
  permanentAddress         String?
  city                     String?
  country                  String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // Employment details
  departmentId       Int
  companyId          Int?
  locationId         Int?
  designation        String
  team               String?
  jobTier            JobTier?
  employmentStatus   EmploymentStatus
  lifecycleStage     EmployeeLifecycleStage @default(ACTIVE)
  dateOfJoining      DateTime
  dateOfLeaving      DateTime?
  probationEndDate   DateTime?
  exitReason         String?
  reportingManagerId Int?

  // Banking
  bankName          String?
  bankAccountNumber String?
  bankAccountStatus String?
  bankBranch        String?
  iban              String?
  bankAccountTitle  String?

  // Extended personal info
  bloodGroup           String?
  passportNumber       String?
  passportExpiry       DateTime?
  maritalStatus        String?
  nationality          String?
  lastDegree           String?
  previousOrganization String?
  referenceCheck       String?
  education            Json? // { degree, institution, year, gpa }
  references           Json? // [{ name, relation, phone, email }]

  // Digital photo
  photoUrl String?

  // Free-form responsibilities / duties — markdown-friendly text edited by
  // the employee's manager. Lives next to designation (which is the formal
  // job title) — designation = "what they're called", responsibilities =
  // "what they actually do day-to-day".
  responsibilities String? @db.Text

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department                  Department      @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  company                     Company?        @relation(fields: [companyId], references: [id])
  location                    Location?       @relation(fields: [locationId], references: [id])
  reportingManager            Employee?       @relation("ReportingManager", fields: [reportingManagerId], references: [id])
  directReports               Employee[]      @relation("ReportingManager")
  orgAssignmentsAsSubordinate OrgAssignment[] @relation("AssignmentSubordinate")
  orgAssignmentsAsManager     OrgAssignment[] @relation("AssignmentManager")

  user                 User?
  assetAssignments     AssetAssignment[]
  assetAssignmentsByMe AssetAssignment[]     @relation("AssignedBy")
  assetTransfers       AssetTransfer[]       @relation("TransferredBy")
  offerLetters         OfferLetter[]
  onboardingSubmission OnboardingSubmission?
  onboardingTasks      OnboardingTask[]
  documents            EmployeeDocument[]
  marketplaces         EmployeeMarketplace[]
  digitalAccess        DigitalAccess[]
  exitRecord           EmployeeExit?
  salaryHistory        SalaryHistory[]
  bonuses              Bonus[]
  expenses             Expense[]             @relation("SubmittedBy")
  payrollItems         PayrollItem[]
  commissions          Commission[]
  deductions           Deduction[]
  billingSplits        BillingSplit[]
  employeeCompanies    EmployeeCompany[]
  ownedServices        DigitalService[]      @relation("DigitalServiceOwner")
  accessRequests       DigitalAccessRequest[]
  // Requests where this employee was explicitly named as the approver
  // (the "Send to" picker on the access modal). Distinct from
  // accessRequests, which are requests *they* filed.
  routedAccessRequests DigitalAccessRequest[] @relation("DigitalAccessRequestSendTo")

  @@map("employees")
}

// ========================
// ORG ASSIGNMENTS (effective-dated reporting + matrix/dotted-line)
// ========================
//
// Source of truth for "who reports to whom, and since when".
// `Employee.reportingManagerId` is kept as a denormalized cache of the
// current SOLID-line manager — mutations go through `lib/services/orgTreeService.ts`,
// which writes through to keep the cache in sync.
//
// Update rule: never UPDATE an existing row. To change a manager,
// close the open row (validTo = now()) and INSERT a new one.
//
// Invariants enforced at the service layer (not via DB constraint):
//   - At most one OPEN row (validTo IS NULL) per (employeeId, relationshipType).
//   - validFrom <= validTo when validTo is non-null.
model OrgAssignment {
  id               Int                 @id @default(autoincrement())
  employeeId       Int
  managerId        Int
  relationshipType OrgRelationshipType @default(SOLID)
  validFrom        DateTime
  validTo          DateTime?
  reason           String?
  createdById      Int?
  createdAt        DateTime            @default(now())

  employee  Employee @relation("AssignmentSubordinate", fields: [employeeId], references: [id], onDelete: Cascade)
  manager   Employee @relation("AssignmentManager", fields: [managerId], references: [id])
  createdBy User?    @relation("AssignmentCreatedBy", fields: [createdById], references: [id])

  @@index([employeeId, validFrom])
  @@index([managerId, validFrom])
  @@index([validFrom, validTo])
  @@map("org_assignments")
}

// ========================
// MARKETPLACES (e-commerce channels each employee owns)
// ========================
//
// Many-to-many between Employee and Marketplace. Lets an exec see which
// marketplaces a person handles (Amazon, Walmart, eBay, Back Market, ...).
// Catalog is editable from /master-data/marketplaces so HR can add new
// channels without a deploy.
model Marketplace {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees EmployeeMarketplace[]

  @@map("marketplaces")
}

model EmployeeMarketplace {
  employeeId    Int
  marketplaceId Int
  assignedAt    DateTime @default(now())

  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Cascade)

  @@id([employeeId, marketplaceId])
  @@index([marketplaceId])
  @@map("employee_marketplaces")
}

model EmployeeCompany {
  id         Int      @id @default(autoincrement())
  employeeId Int
  companyId  Int
  assignedAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([employeeId, companyId])
  @@map("employee_companies")
}

model OfferLetter {
  id                  Int       @id @default(autoincrement())
  employeeId          Int?
  // Candidate identification (used before Employee record exists)
  candidateName       String?
  candidateEmail      String?
  // Template choice
  templateType        String    @default("PERMANENT") // PERMANENT, PROBATION, CONSULTANT, CUSTOM
  offerDate           DateTime  @default(now())
  position            String
  department          String?
  companyName         String? // Which sub-company
  salary              Decimal   @db.Decimal(12, 2)
  currency            String    @default("PKR")
  startDate           DateTime
  // Extra contract terms
  probationPeriod     String? // e.g. "3 months"
  reportingTo         String?
  contractType        String? // REMOTE, HYBRID, ONSITE
  commissionStructure String? // For sales roles
  benefits            String?
  workingHours        String?
  terms               String?
  customBody          String? // For CUSTOM template
  status              String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, DECLINED
  sentAt              DateTime?
  acceptedDate        DateTime?
  documentUrl         String?
  createdBy           Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  employee Employee? @relation(fields: [employeeId], references: [id])

  @@map("offer_letters")
}

model OnboardingSubmission {
  id                Int         @id @default(autoincrement())
  employeeId        Int?        @unique
  // Token-based public access (before Employee exists)
  token             String?     @unique
  tokenExpiresAt    DateTime?
  candidateName     String?
  candidateEmail    String?
  position          String?
  companyName       String?
  // Structured org links — set by admin when creating the invite
  companyId         Int?
  departmentId      Int?
  company           Company?    @relation(fields: [companyId], references: [id])
  department        Department? @relation(fields: [departmentId], references: [id])
  // Submitted data
  personalDetails   Json? // Full personal details submitted by employee
  bankDetails       Json? // Bank info submitted
  emergencyContact  Json?
  educationHistory  Json? // Array of education records
  workHistory       Json? // Array of previous employers
  references        Json? // Array of references
  documentsUploaded Boolean     @default(false)
  documentsMeta     Json? // Metadata for uploaded documents
  isComplete        Boolean     @default(false)
  submittedAt       DateTime?
  reviewStatus      String      @default("PENDING") // PENDING, APPROVED, REJECTED, NEEDS_REVISION
  reviewedBy        Int?
  reviewedAt        DateTime?
  reviewNotes       String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  employee Employee? @relation(fields: [employeeId], references: [id])

  @@map("onboarding_submissions")
}

model OnboardingTask {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  category    String // IT, HR, FINANCE, MANAGER
  title       String
  description String?
  // Role that owns the task (SUPER_ADMIN, ADMIN_IT, FINANCE, EMPLOYEE)
  ownerRole   String
  dueDate     DateTime?
  status      String    @default("PENDING") // PENDING, DONE, SKIPPED
  completedAt DateTime?
  completedBy Int?
  sortOrder   Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("onboarding_tasks")
}

model EmailTemplate {
  id          Int      @id @default(autoincrement())
  templateKey String   @unique // e.g. "OFFER_PERMANENT", "ONBOARDING_INVITE"
  name        String
  category    String // OFFER, ONBOARDING, EXPENSE, PAYROLL, ASSET, GENERAL
  subject     String
  bodyHtml    String   @db.Text
  bodyText    String?  @db.Text
  mergeFields Json? // Array of supported merge field keys
  description String?
  isActive    Boolean  @default(true)
  createdBy   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("email_templates")
}

model EmployeeDocument {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  documentType String // CNIC, RESUME, DEGREE, CONTRACT, NDA, OTHER
  fileName     String
  fileUrl      String
  uploadedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_documents")
}

model DigitalAccess {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  serviceName String // O365, Claude, GitHub Copilot, VPN, Biometric, etc.
  accountId   String? // Email or username for the service
  isActive    Boolean   @default(true)
  grantedDate DateTime  @default(now())
  revokedDate DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("digital_access")
}

// Catalog of SaaS / digital tools that employees can request access to.
// Admin-maintained; surfaced read-only to employees on /access-catalog.
model DigitalService {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  description     String?
  category        String? // "Communication", "Development", "Design", etc.
  iconUrl         String?
  defaultPlan     String? // "Business Standard", "Pro", etc.
  // Optional owner who reviews requests for this service. Falls back to
  // any ADMIN user if null.
  ownerEmployeeId Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner    Employee?              @relation("DigitalServiceOwner", fields: [ownerEmployeeId], references: [id])
  requests DigitalAccessRequest[]

  @@map("digital_services")
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// Request from an employee for access to a DigitalService. Approving a
// request creates a DigitalAccess record (the existing per-employee
// grant table) — this model just queues the workflow.
model DigitalAccessRequest {
  id           Int                 @id @default(autoincrement())
  employeeId   Int
  serviceId    Int
  // Optional explicit approver chosen by the requester at submit time.
  // Lets a user direct the request to (e.g.) a team lead or the design
  // owner instead of the default admin/service-owner fan-out. Null =
  // no explicit pick, fall back to the standard fan-out.
  sendToEmployeeId Int?
  status       AccessRequestStatus @default(PENDING)
  notes        String? // employee's reason for requesting
  reviewNotes  String? // admin's response on approve/reject
  requestedAt  DateTime            @default(now())
  reviewedAt   DateTime?
  reviewedById Int? // user.id of the reviewer
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  employee Employee       @relation(fields: [employeeId], references: [id])
  sendTo   Employee?      @relation("DigitalAccessRequestSendTo", fields: [sendToEmployeeId], references: [id])
  service  DigitalService @relation(fields: [serviceId], references: [id])
  reviewer User?          @relation(fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([serviceId])
  @@index([status])
  @@index([sendToEmployeeId])
  @@map("digital_access_requests")
}

model EmployeeExit {
  id              Int      @id @default(autoincrement())
  employeeId      Int      @unique
  exitDate        DateTime
  reason          String?
  exitType        String   @default("RESIGNATION") // RESIGNATION, TERMINATION, CONTRACT_END
  clearanceStatus Json? // Checklist items: assets returned, access revoked, etc.
  finalSettlement Decimal? @db.Decimal(12, 2)
  isComplete      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_exits")
}

// ========================
// ASSET MANAGEMENT
// ========================

model AssetCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  code        String    @unique
  assetType   AssetType @default(HARDWARE)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assets Asset[]

  @@map("asset_categories")
}

model Asset {
  id             Int            @id @default(autoincrement())
  assetTag       String         @unique
  serialNumber   String
  categoryId     Int
  manufacturer   String
  model          String
  description    String?
  purchaseDate   DateTime?
  purchasePrice  Decimal        @default(0) @db.Decimal(12, 2)
  currency       String         @default("PKR")
  warrantyExpiry DateTime?
  condition      AssetCondition @default(WORKING)
  companyId      Int?
  locationId     Int?
  isAssigned     Boolean        @default(false)
  isRetired      Boolean        @default(false)
  retiredDate    DateTime?
  retireReason   String?
  specs          Json?
  photoUrl       String?
  batchId        String?
  // Raw holder label from source sheet when we can't resolve to a real employee
  // (e.g. "Available", "Damage", "Home Office", "Qasim Sir House")
  assignedToName String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  category    AssetCategory     @relation(fields: [categoryId], references: [id])
  company     Company?          @relation(fields: [companyId], references: [id])
  location    Location?         @relation(fields: [locationId], references: [id])
  assignments AssetAssignment[]
  transfers   AssetTransfer[]

  @@map("assets")
}

model AssetAssignment {
  id                    Int             @id @default(autoincrement())
  assetId               Int
  employeeId            Int
  assignedById          Int?
  assignedDate          DateTime        @default(now())
  returnedDate          DateTime?
  conditionAtAssignment AssetCondition
  conditionAtReturn     AssetCondition?
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee   Employee  @relation(fields: [employeeId], references: [id])
  assignedBy Employee? @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@map("asset_assignments")
}

model AssetTransfer {
  id            Int      @id @default(autoincrement())
  assetId       Int
  fromCompanyId Int
  toCompanyId   Int
  transferredBy Int?
  transferDate  DateTime @default(now())
  reason        String?
  createdAt     DateTime @default(now())

  asset                 Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fromCompany           Company   @relation("FromCompany", fields: [fromCompanyId], references: [id])
  toCompany             Company   @relation("ToCompany", fields: [toCompanyId], references: [id])
  transferredByEmployee Employee? @relation("TransferredBy", fields: [transferredBy], references: [id])

  @@map("asset_transfers")
}

// ========================
// EXPENSE MANAGEMENT
// ========================

model ExpenseCategory {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  code         String   @unique
  description  String?
  isGlobal     Boolean  @default(true) // Available across all companies
  departmentId Int? // If company-specific
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department? @relation(fields: [departmentId], references: [id])
  expenses   Expense[]

  @@map("expense_categories")
}

model Expense {
  id              Int           @id @default(autoincrement())
  expenseNumber   String        @unique // EXP-YYYY-MM-XXXX
  categoryId      Int
  companyId       Int
  departmentId    Int?
  submittedById   Int
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("PKR")
  description     String
  paymentMethod   String? // CASH, BANK_TRANSFER, CREDIT_CARD, PETTY_CASH
  invoiceNumber   String?
  receiptUrl      String? // Photo/PDF upload
  vendor          String?
  expenseDate     DateTime
  status          ExpenseStatus @default(PENDING)
  rejectionReason String?
  revisionNotes   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  category    ExpenseCategory   @relation(fields: [categoryId], references: [id])
  company     Company           @relation(fields: [companyId], references: [id])
  department  Department?       @relation(fields: [departmentId], references: [id])
  submittedBy Employee          @relation("SubmittedBy", fields: [submittedById], references: [id], onDelete: Restrict)
  approvals   ExpenseApproval[]

  @@map("expenses")
}

model ExpenseApproval {
  id           Int      @id @default(autoincrement())
  expenseId    Int
  approvedById Int
  action       String // APPROVED, REJECTED, NEEDS_REVISION
  comments     String?
  createdAt    DateTime @default(now())

  expense    Expense @relation(fields: [expenseId], references: [id])
  approvedBy User    @relation(fields: [approvedById], references: [id])

  @@map("expense_approvals")
}

// ========================
// FINANCE & PAYROLL
// ========================

model SalaryHistory {
  id            Int       @id @default(autoincrement())
  employeeId    Int
  baseSalary    Decimal   @db.Decimal(12, 2)
  currency      String    @default("PKR")
  effectiveFrom DateTime
  effectiveTo   DateTime?
  incrementPct  Decimal?  @db.Decimal(5, 2) // Percentage increase from previous
  reason        String? // Annual increment, promotion, etc.
  createdAt     DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("salary_history")
}

model Commission {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("PKR")
  description String
  period      String // e.g., "2026-03"
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("commissions")
}

// One-time bonus awarded to an employee. Distinct from Commission
// (which is period-based and usually variable per pay cycle) and from
// SalaryHistory (which captures the recurring base). A Bonus row
// represents a single discretionary award — Eid bonus, signing bonus,
// performance award. `period` is optional: free-form when the bonus
// is associated with a particular cycle ("2026-Q1"), null when it's
// truly one-off.
model Bonus {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("PKR")
  reason      String // e.g., "Eid bonus 2026", "Q1 performance"
  period      String?  // e.g., "2026-Q1" — optional
  awardedDate DateTime @default(now())
  isPaid      Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([awardedDate])
  @@map("bonuses")
}

model Deduction {
  id            Int      @id @default(autoincrement())
  employeeId    Int
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("PKR")
  deductionType String // TAX, LOAN, ADVANCE, INSURANCE, OTHER
  description   String?
  period        String // e.g., "2026-03"
  createdAt     DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("deductions")
}

model PayrollRun {
  id              Int           @id @default(autoincrement())
  period          String // e.g., "2026-03"
  companyId       Int?
  status          PayrollStatus @default(DRAFT)
  totalGross      Decimal       @default(0) @db.Decimal(14, 2)
  totalDeductions Decimal       @default(0) @db.Decimal(14, 2)
  totalNet        Decimal       @default(0) @db.Decimal(14, 2)
  processedAt     DateTime?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company Company?      @relation(fields: [companyId], references: [id])
  items   PayrollItem[]

  @@unique([period, companyId])
  @@map("payroll_runs")
}

model PayrollItem {
  id           Int      @id @default(autoincrement())
  payrollRunId Int
  employeeId   Int
  baseSalary   Decimal  @db.Decimal(12, 2)
  commissions  Decimal  @default(0) @db.Decimal(12, 2)
  bonuses      Decimal  @default(0) @db.Decimal(12, 2)
  deductions   Decimal  @default(0) @db.Decimal(12, 2)
  netPay       Decimal  @db.Decimal(12, 2)
  currency     String   @default("PKR")
  createdAt    DateTime @default(now())

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@map("payroll_items")
}

model BillingSplit {
  id            Int       @id @default(autoincrement())
  employeeId    Int
  companyId     Int
  percentage    Decimal   @db.Decimal(5, 2) // What % of this employee is billed to this company
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])

  @@map("billing_splits")
}

// ========================
// MONTHLY REPORTS
// ========================

enum ReportStatus {
  DRAFT
  UNDER_REVIEW
  SENT
  ACKNOWLEDGED
}

model MonthlyReport {
  id             Int          @id @default(autoincrement())
  period         String // e.g., "2026-03"
  companyId      Int?
  title          String
  status         ReportStatus @default(DRAFT)
  summary        Json? // { totalExpenses, totalPayroll, assetCount, headcount, etc. }
  generatedBy    Int?
  reviewedBy     Int?
  sentAt         DateTime?
  acknowledgedAt DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("monthly_reports")
}

// ========================
// NOTIFICATIONS
// ========================

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType @default(GENERAL)
  title     String
  message   String
  link      String? // URL to navigate to
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ========================
// IDEMPOTENCY / REQUEST LOG
// ========================

model RequestLog {
  id             Int      @id @default(autoincrement())
  idempotencyKey String   @unique
  method         String
  path           String
  statusCode     Int
  responseBody   Json?
  createdAt      DateTime @default(now())

  @@index([idempotencyKey])
  @@map("request_logs")
}

// ========================
// AUDIT TRAIL
// ========================

model AuditLog {
  id          Int         @id @default(autoincrement())
  tableName   String
  recordId    Int
  action      AuditAction
  changedById Int?
  changedBy   User?       @relation("AuditUser", fields: [changedById], references: [id])
  ipAddress   String?
  module      String? // ASSET, EMPLOYEE, EXPENSE, PAYROLL, etc.
  oldValues   Json?
  newValues   Json?
  createdAt   DateTime    @default(now())

  @@map("audit_logs")
}

// ========================
// FINANCE LEDGER (cash-flow master ledger)
// ========================
//
// The legacy spreadsheet was a single running-balance cash ledger. The
// ERP version splits the ENTRY into specialised sub-models (Bill /
// Cheque / OpexEntry) that each commit a paired LedgerEntry in the same
// transaction. The Master Ledger view is just `LedgerEntry` listed in
// trans-date order with a running balance computed at read time.
//
// Immutability: ledger entries are insert-only. To "fix" an entry the
// admin posts a contra entry (reversesEntryId points back at the
// original) — the original row stays in place with a "Reversed by" badge.

// Standardised "Account Head" — the dropdown that prevents categorisation
// fragmentation. Seeded from the spec's governance list; admins can add
// more via /finance/ledger/categories later.
model LedgerCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique // short code for compact display, e.g. ADV, BANK_FEE
  // 'income' = credit-only, 'expense' = debit-only, 'either' = both allowed
  // (e.g. a refund debit category that also takes credits).
  type        String   @default("expense")
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ledgerEntries LedgerEntry[]
  bills         Bill[]
  opexEntries   OpexEntry[]

  @@map("ledger_categories")
}

enum LedgerSource {
  MANUAL // Direct ledger insert (admin override w/ attachment)
  BILL // Posted from a Bill row
  CHEQUE // Posted from a Cheque row
  OPEX // Posted from an OpexEntry
  EXPENSE // Auto-posted from an approved Expense
  PAYROLL // Auto-posted from a paid PayrollRun item
  OPENING // Opening balance entry (one per company, one-time)
}

// The Master Ledger row. One per cash event. Insert-only.
model LedgerEntry {
  id         Int          @id @default(autoincrement())
  // Human-friendly serial number ("S#" in the legacy sheet). Generated by
  // the API on insert with an advisory lock so concurrent posts don't
  // collide. Format: SN-000001.
  serialNo   String       @unique
  transDate  DateTime
  transDetail String      @db.VarChar(500)
  categoryId Int
  // Quantity + unitPrice are kept as separate columns even though the
  // money columns below carry the truth — useful for itemised receipts
  // (e.g. 4 × 350 = 1400) without needing a line-items table for v1.
  quantity   Decimal      @default(0) @db.Decimal(12, 2)
  unitPrice  Decimal      @default(0) @db.Decimal(18, 2)
  // Exactly one of these is non-zero. Validated server-side.
  creditAmt  Decimal      @default(0) @db.Decimal(18, 2)
  debitAmt   Decimal      @default(0) @db.Decimal(18, 2)
  // Running balance AFTER this entry was applied. Recomputed by the
  // posting service in chronological order. Stored to make the read view
  // fast — read endpoints don't have to recompute SUMs over the whole
  // table on every page load.
  runningBal Decimal      @default(0) @db.Decimal(18, 2)
  currency   String       @default("PKR")
  companyId  Int? // null = corporate / cross-company (e.g. group-level expense)
  // Where this entry came from. Sub-modules set both source + sourceId
  // so the admin can click the row and jump to the originating record.
  source     LedgerSource @default(MANUAL)
  sourceId   Int? // FK target depends on source; not enforced
  // Image/receipt URL — required when debitAmt > 0. Stored on the entry
  // itself (rather than only on the source) so the master ledger view
  // can show the attachment without joining out.
  attachmentUrl  String?
  // EXIF + capture metadata snapshot — { capturedAt, lat, lon, etc. }
  attachmentMeta Json?
  // Whether the system flagged the attachment for review (e.g. capture
  // date drifted >7 days from transDate). Admin can clear the flag.
  reviewFlag     Boolean   @default(false)
  reviewNotes    String?
  // Reversing-entry linkage. If reversesEntryId is set, this row IS the
  // contra. The original row's "isReversed" flips to true.
  reversesEntryId Int?
  isReversed      Boolean  @default(false)
  // Audit
  createdById Int
  createdAt   DateTime @default(now())
  // No updatedAt — entries are insert-only.

  category   LedgerCategory @relation(fields: [categoryId], references: [id])
  company    Company?       @relation(fields: [companyId], references: [id])
  reverses   LedgerEntry?   @relation("LedgerReversal", fields: [reversesEntryId], references: [id])
  reversedBy LedgerEntry[]  @relation("LedgerReversal")
  createdBy  User           @relation(fields: [createdById], references: [id])
  bill       Bill?
  cheque     Cheque?
  opexEntry  OpexEntry?

  @@index([transDate])
  @@index([source])
  @@index([companyId])
  @@map("ledger_entries")
}

enum BillStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// Vendor invoice / "Bill To" record.
model Bill {
  id           Int        @id @default(autoincrement())
  billNumber   String     @unique
  vendorName   String
  vendorContact String?   // optional phone/email for follow-up
  amount       Decimal    @db.Decimal(18, 2)
  currency     String     @default("PKR")
  billDate     DateTime
  dueDate      DateTime?
  categoryId   Int
  companyId    Int?
  status       BillStatus @default(PENDING)
  description  String?    @db.VarChar(500)
  // Image hard-stop: a bill cannot be saved without a scan/photo.
  attachmentUrl String
  attachmentMeta Json?
  // Once paid (status flips PAID), the linked LedgerEntry holds the
  // debit. PENDING bills don't post to the ledger until paid.
  ledgerEntryId Int?       @unique
  paidAt        DateTime?
  createdById   Int
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  category    LedgerCategory @relation(fields: [categoryId], references: [id])
  company     Company?       @relation(fields: [companyId], references: [id])
  ledgerEntry LedgerEntry?   @relation(fields: [ledgerEntryId], references: [id])
  createdBy   User           @relation(fields: [createdById], references: [id])

  @@index([status])
  @@index([dueDate])
  @@map("bills")
}

enum ChequeDirection {
  RECEIVED // cheque coming in — credit
  ISSUED // cheque going out — debit
}

enum ChequeStatus {
  PENDING // not yet cleared
  CLEARED // cleared by the bank
  BOUNCED // returned
  CANCELLED
}

// Bank cheque tracker. Image of the cheque is required.
model Cheque {
  id           Int             @id @default(autoincrement())
  instrumentNo String          // e.g. BAHL Cheque No 10081161
  bankName     String          // e.g. Bank Al Habib Limited
  partyName    String          // payer (if RECEIVED) or payee (if ISSUED)
  chequeDate   DateTime
  amount       Decimal         @db.Decimal(18, 2)
  currency     String          @default("PKR")
  direction    ChequeDirection
  status       ChequeStatus    @default(PENDING)
  companyId    Int?
  description  String?         @db.VarChar(500)
  // Image hard-stop on Cheque too — the spec elevates Bills + Cheques
  // to the same evidence requirement as cash-out OPEX.
  attachmentUrl String
  attachmentMeta Json?
  // Posts to the ledger only when status flips CLEARED.
  ledgerEntryId Int?            @unique
  clearedAt     DateTime?
  createdById   Int
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  company     Company?     @relation(fields: [companyId], references: [id])
  ledgerEntry LedgerEntry? @relation(fields: [ledgerEntryId], references: [id])
  createdBy   User         @relation(fields: [createdById], references: [id])

  @@unique([bankName, instrumentNo])
  @@index([status])
  @@map("cheques")
}

enum OpexType {
  RENTAL
  MAINTENANCE
  DONATION
  SALARY
  UTILITY
  OTHER
}

// Recurring operational expense — rentals, maintenance, donations,
// non-payroll-system salaries (e.g. ALS School - Mukhtar Salary).
model OpexEntry {
  id         Int      @id @default(autoincrement())
  type       OpexType
  recipient  String   // who got paid (vendor, person, charity)
  // Period this OPEX covers, free-form so it can hold "April 2026" or
  // "Q2 2026" or a date — UI parses what it needs.
  period     String?
  amount     Decimal  @db.Decimal(18, 2)
  currency   String   @default("PKR")
  categoryId Int
  companyId  Int?
  description String?  @db.VarChar(500)
  // Image hard-stop — receipt / voucher / signed slip required.
  attachmentUrl String
  attachmentMeta Json?
  ledgerEntryId Int?     @unique
  paidAt        DateTime @default(now())
  createdById   Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category    LedgerCategory @relation(fields: [categoryId], references: [id])
  company     Company?       @relation(fields: [companyId], references: [id])
  ledgerEntry LedgerEntry?   @relation(fields: [ledgerEntryId], references: [id])
  createdBy   User           @relation(fields: [createdById], references: [id])

  @@index([type])
  @@index([paidAt])
  @@map("opex_entries")
}
